<h1>Contáctanos</h1>
<p>Déjanos tu mensaje y te responderemos a la brevedad.</p>

<form action="/contact" method="POST" style="max-width: 400px;">
    <div style="margin-bottom: 15px;">
        <label for="nombre">Tu Nombre:</label><br>
        <input type="text" id="nombre" name="nombre" required style="width: 100%; padding: 8px;">
    </div>
    <div style="margin-bottom: 15px;">
        <label for="mensaje">Mensaje:</label><br>
        <textarea id="mensaje" name="mensaje" required style="width: 100%; padding: 8px; height: 100px;"></textarea>
    </div>
    <button type="submit" style="padding: 10px 15px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer;">
        Enviar Mensaje
    </button>
</form>